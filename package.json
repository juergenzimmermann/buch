{
  "name": "buch",
  "version": "2026.10.1",
  "private": true,
  "description": "Beispiel",
  "keywords": [
    "GraphQL",
    "Hono",
    "Integrationstests",
    "JWT",
    "Keycloak",
    "Lasttests",
    "Logging",
    "Mailing",
    "OIDC",
    "ORM",
    "Oxfmt",
    "Oxlint",
    "Pino",
    "PostgreSQL",
    "Prisma",
    "REST",
    "TypeScript",
    "Typedoc",
    "Unit-Tests",
    "Validierung",
    "Yoga",
    "Zod",
    "k6",
    "pnpm"
  ],
  "license": "GPL-3.0",
  "author": "Juergen Zimmermann <Juergen.Zimmermann@h-ka.de> (https://www.h-ka.de)",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/index.mts",
    "test": "vitest",
    "asciidoctor": "node scripts/asciidoctor.mts",
    "dev": "node --env-file=.env --watch src/index.mts",
    "dev:bun": "bun --watch src/index.mts",
    "hello": "node --watch src/index-hello.mts",
    "hello:bun": "bun --watch src/index-hello.mts",
    "k6": "k6 run test\\lasttest\\script.ts",
    "leasot": "leasot --exit-nicely src/**/*.mts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "sonar": "node scripts/sonar-scanner.mts",
    "tsc": "tsc --pretty"
  },
  "dependencies": {
    "@hono/node-server": "2.0.11",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "@prisma/sqlcommenter-query-insights": "7.9.0",
    "dotenv": "17.4.2",
    "figlet": "1.11.1",
    "graphql": "17.0.2",
    "graphql-yoga": "5.21.2",
    "hono": "4.12.31",
    "isbn3": "2.0.9",
    "jose": "6.2.3",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "smol-toml": "1.7.0",
    "temporal-polyfill": "1.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@asciidoctor/core": "4.0.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tsconfig/node26": "26.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.14",
    "@types/k6": "2.0.1",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "asciidoctor-kroki": "1.0.1",
    "globals": "17.7.0",
    "leasot": "14.4.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "prisma": "7.9.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vitest-mock-extended": "5.1.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.14"
    },
    "leasot": {
      "lodash": "4.18.1"
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1",
      "onFail": "warn"
    },
    "runtime": [
      {
        "name": "node",
        "version": "26.5.0",
        "onFail": "warn"
      },
      {
        "name": "bun",
        "version": "1.3.14",
        "onFail": "warn"
      }
    ]
  },
  "engines": {
    "bun": "1.3.14",
    "node": "26.5.0",
    "pnpm": "11.15.1"
  }
}
