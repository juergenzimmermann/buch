{
  "name": "buch",
  "version": "2026.4.1",
  "private": true,
  "description": "Beispiel",
  "keywords": [
    "Bun",
    "ESM",
    "REST",
    "Hono",
    "Validierung",
    "Zod",
    "ORM",
    "Prisma",
    "PostgreSQL",
    "JWT",
    "OIDC",
    "Keycloak",
    "Mailing",
    "Logging",
    "GraphQL",
    "Yoga",
    "Pino",
    "TypeScript",
    "Integrationstests",
    "Unit-Tests",
    "Lasttests",
    "k6",
    "ESLint",
    "Prettier",
    "Typedoc"
  ],
  "license": "GPL-3.0",
  "author": "Juergen Zimmermann <Juergen.Zimmermann@h-ka.de> (https://www.h-ka.de)",
  "type": "module",
  "scripts": {
    "start": "bun src/index.mts",
    "test": "vitest --config ./vitest.config.mts --bail 1",
    "asciidoctor": "node scripts/asciidoctor.mts",
    "dev": "bun --watch src/index.mts",
    "eslint": "eslint --concurrency auto src test package.json",
    "hello": "bun --watch src/index-hello.mts",
    "k6": "k6 run test\\lasttest\\script.ts",
    "leasot": "leasot --exit-nicely src/**/*.mts",
    "prettier": "prettier -w  \"src/**/*.mts\" \"test/**/*.ts\" \"package.json\"",
    "prettier:check": "prettier --cache --check \"src/**/*.mts\" \"test/**/*.ts\" \"package.json\"",
    "sonar": "bun scripts/sonar-scanner.mts",
    "tsc": "tsc --pretty",
    "tsgo": "tsgo --project tsconfig.json --stableTypeOrdering"
  },
  "overrides": {
    "@hono/node-server": "1.19.11",
    "hono": "4.12.7",
    "lodash": "4.17.23",
    "tar": "7.5.9"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@prisma/sqlcommenter-query-insights": "7.5.0",
    "dotenv": "17.3.1",
    "figlet": "1.11.0",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "hono": "4.12.7",
    "isbn3": "2.0.6",
    "jose": "6.2.1",
    "nodemailer": "8.0.2",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "smol-toml": "1.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@asciidoctor/core": "3.0.4",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/js": "9.39.2",
    "@hono/node-server": "1.19.11",
    "@prettier/plugin-oxc": "0.1.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.10",
    "@types/eslint-plugin-security": "3.0.1",
    "@types/k6": "1.6.0",
    "@types/nodemailer": "7.0.11",
    "@types/pg": "8.18.0",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.11",
    "@vitest/ui": "4.1.0",
    "asciidoctor-kroki": "0.18.1",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-package-json": "0.90.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "leasot": "14.4.0",
    "madge": "8.0.0",
    "prettier": "3.8.1",
    "prisma": "7.5.0",
    "typescript": "6.0.1-rc",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.0",
    "vitest": "4.1.0",
    "vitest-mock-extended": "3.1.0"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=25.8.1"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "version": "1.3.10",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "version": "1.3.10",
      "onFail": "error"
    }
  }
}
